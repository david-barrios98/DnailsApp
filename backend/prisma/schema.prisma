generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// En V1 usamos SQLite local para arrancar rápido.
// Luego puede migrar 1:1 a Postgres (Supabase) sin cambiar el modelo.

model ServiceCategory {
  id        Int      @id @default(autoincrement())
  code      String   @unique // UÑAS | DEPILACION | CEJAS_Y_PESTANAS
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services Service[]
}

model Neighborhood {
  id         Int      @id @default(autoincrement())
  locality   String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  addresses Address[]

  @@unique([locality, name])
  @@index([locality])
}

model Role {
  id        Int      @id @default(autoincrement())
  code      RoleCode @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users UserRole[]
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  passwordHash String
  fullName     String
  phoneE164    String?    @unique
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  roles UserRole[]
  auditLogs AuditLog[]
}

model UserRole {
  userId Int
  roleId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorUserId Int?
  action     String
  entity     String
  entityId   Int?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entity, entityId])
}

model Customer {
  id        Int      @id @default(autoincrement())
  fullName  String
  phoneE164 String?  @unique
  email     String?  @unique
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
  appointments Appointment[]
}

model Address {
  id          Int      @id @default(autoincrement())
  customerId  Int?
  neighborhoodId Int?
  label       String?
  line1       String
  mapsUrl     String?
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  neighborhood Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  appointments Appointment[]

  @@index([neighborhoodId])
}

model Service {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  name        String
  // duración estimada en minutos (rango) para agendamiento
  durationMin Int
  durationMax Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  prices   ServicePrice[]
  planned AppointmentPlannedService[]
  actual AppointmentActualService[]

  @@unique([categoryId, name])
}

// Normalización de precios: el precio puede cambiar sin reescribir el catálogo.
model ServicePrice {
  id         Int      @id @default(autoincrement())
  serviceId  Int
  amountCOP  Int
  currency   String   @default("COP")
  effectiveFrom DateTime @default(now())
  effectiveTo   DateTime?
  createdAt  DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, effectiveFrom])
}

model FormSubmission {
  id        Int      @id @default(autoincrement())
  sourceKey String   @unique
  payload   Json
  createdAt DateTime @default(now())

  appointment Appointment?
}

model Appointment {
  id            Int      @id @default(autoincrement())
  customerId    Int
  addressId     Int?
  startAt       DateTime?
  endAt         DateTime?
  // Preferencias del cliente desde el Form (antes de confirmación de ruta)
  requestedStartAt   DateTime?
  requestedTimeText  String?
  requestedFlexible  Boolean?
  // "lead" puede ser quien agenda, aunque el servicio sea para otra(s) persona(s)
  leadName      String?
  leadPhoneE164 String?

  status        AppointmentStatus @default(PENDING)
  notes         String?

  // Control de origen (para trazabilidad con Google Forms/Sheets)
  source        String   @default("google_form")
  formSubmissionId Int? @unique

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  address  Address?  @relation(fields: [addressId], references: [id], onDelete: SetNull)
  formSubmission FormSubmission? @relation(fields: [formSubmissionId], references: [id], onDelete: SetNull)

  participants AppointmentParticipant[]
  plannedServices AppointmentPlannedService[]
  actualServices  AppointmentActualService[]
  payments Payment[]

  @@index([status, startAt])
}

model AppointmentParticipant {
  id            Int      @id @default(autoincrement())
  appointmentId Int
  fullName      String?
  // Ej: "para mí", "para alguien más", "grupo"
  roleLabel     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model AppointmentPlannedService {
  id            Int      @id @default(autoincrement())
  appointmentId Int
  serviceId     Int
  quantity      Int      @default(1)
  priceCOP      Int?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@unique([appointmentId, serviceId])
}

model AppointmentActualService {
  id            Int      @id @default(autoincrement())
  appointmentId Int
  serviceId     Int
  quantity      Int      @default(1)
  priceCOP      Int?
  // Si fue agregado en domicilio o cambió respecto a lo planeado
  origin        ActualServiceOrigin @default(ON_SITE_ADDED)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([appointmentId])
}

model Payment {
  id            Int      @id @default(autoincrement())
  appointmentId Int
  amountCOP     Int
  method        PaymentMethod
  paidAt        DateTime @default(now())
  reference     String?
  notes         String?

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([paidAt])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_ROUTE
  IN_SERVICE
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentMethod {
  CASH
  TRANSFER
  NEQUI
  DAVIPLATA
  CARD
  OTHER
}

enum ActualServiceOrigin {
  RESERVED
  ON_SITE_CHANGED
  ON_SITE_ADDED
}

enum RoleCode {
  OWNER
  ADMIN
  STAFF
  VIEWER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

