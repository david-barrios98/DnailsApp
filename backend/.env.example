# SQLite file path is relative to `backend/prisma/`
DATABASE_URL="file:./dev2.db"

# (V1) Importación desde Google Sheets como CSV publicado.
# 1) En el Sheet: Archivo -> Compartir -> Publicar en la web -> CSV (hoja de respuestas)
# 2) Pega el link directo al CSV aquí.
GOOGLE_SHEET_CSV_URL=""

# Auth (JWT)
JWT_SECRET="change-me-to-a-long-random-string"

# Token para crear el primer usuario administrador (POST /auth/bootstrap)
BOOTSTRAP_TOKEN="change-me-bootstrap-token"

# Normalización de teléfono por defecto (E.164)
DEFAULT_PHONE_REGION="CO"

