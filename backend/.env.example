# SQLite (ruta relativa a `backend/prisma/`). No uses `?param=…` en la URL: en Windows a veces rompe el nombre del archivo.
DATABASE_URL="file:./dev2.db"

# (V1) Importación desde Google Sheets como CSV publicado.
# 1) En el Sheet: Archivo -> Compartir -> Publicar en la web -> CSV (hoja de respuestas)
# 2) Pega el link directo al CSV aquí.
GOOGLE_SHEET_CSV_URL=""

# Auth (JWT)
JWT_SECRET="change-me-to-a-long-random-string"

# Token para crear el primer usuario administrador (POST /auth/bootstrap)
BOOTSTRAP_TOKEN="change-me-bootstrap-token"

# Normalización de teléfono por defecto (E.164)
DEFAULT_PHONE_REGION="CO"

# 1 = al levantar el API, si no hay ningún usuario, se crea uno (tel + contraseña abajo)
AUTO_SEED_DEV_USER=1
# Teléfono (colombiano 10 díg. o con +57). Contraseña mín. 8 caracteres.
SEED_USER_PHONE=3001234567
SEED_USER_PASSWORD=Dev123456
SEED_USER_FULL_NAME=Usuario de prueba

